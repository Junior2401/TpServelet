/*C4*/SET SCHEMA PUBLIC
drop table if exists Evenement cascade 
drop table if exists organiser cascade 
drop table if exists participer cascade 
drop table if exists Personne cascade 
drop table if exists Ticket cascade 
drop table if exists TypeEvenement cascade 
create table Evenement (capacite integer, date timestamp(6), id bigint generated by default as identity (start with 1), type_evenement_id bigint, description varchar(255), libelle varchar(255), lieu varchar(255), statut varchar(255) check (statut in ('CREE','VALIDE','ANNULE')), primary key (id))
create table organiser (evenement_id bigint not null, organisateur_id bigint not null, primary key (evenement_id, organisateur_id))
create table participer (artiste_id bigint not null, evenement_id bigint not null, primary key (artiste_id, evenement_id))
create table Personne (numero integer, id bigint generated by default as identity (start with 1), type_personne varchar(31) not null, email varchar(255), nom varchar(255), nomDeScene varchar(255), password varchar(255), prenom varchar(255), role varchar(255), rue varchar(255), societe varchar(255), styleArtistique varchar(255), telephone varchar(255), telephonePro varchar(255), ville varchar(255), primary key (id))
create table Ticket (prix integer, dateAchat timestamp(6) not null, dateAnnulation timestamp(6), dateRemboursement timestamp(6), evenement_id bigint, id bigint generated by default as identity (start with 1), utilisateur_id bigint, numeroPlace varchar(255) not null, place varchar(255), statut varchar(255) not null check (statut in ('ACHETE','ANNULE','REMBOURSE')), primary key (id))
create table TypeEvenement (id bigint generated by default as identity (start with 1), description varchar(255), libelle varchar(255), primary key (id))
alter table Evenement add constraint FKaw6qq4sukx3hvryu2pyncevvs foreign key (type_evenement_id) references TypeEvenement
alter table organiser add constraint FKc0eas02lj0gpd3k0gb4w07ea2 foreign key (organisateur_id) references Personne
alter table organiser add constraint FKk1drnkbdyr7o3udknr886ndos foreign key (evenement_id) references Evenement
alter table participer add constraint FK2b4c92c2bbfagf7qcguld7w0g foreign key (artiste_id) references Personne
alter table participer add constraint FKh8yrx8j9nh3o1s3mlhln8hp8p foreign key (evenement_id) references Evenement
alter table Ticket add constraint FKnxp90mos6ebnx1toph4oqo6a foreign key (evenement_id) references Evenement
alter table Ticket add constraint FK2mp1p8sf22tsvdyjdo4b4wgsu foreign key (utilisateur_id) references Personne
